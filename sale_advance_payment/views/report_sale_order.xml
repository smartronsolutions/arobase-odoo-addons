        	<!--version minimalist-->
            <t t-if="request.env['ir.config_parameter'].sudo().get_param('sale_advance_payment.show_advance_payments_in_reports') and doc.account_payment_ids.filtered(lambda p: p.state != 'draft')">
                <br/>
                <strong>
                    <i class="fa fa-credit-card"/> Paiements reçus
                </strong>
                <table class="table table-sm">
                    <t t-foreach="doc.account_payment_ids.filtered(lambda p: p.state != 'draft').sorted('date')" t-as="payment">
                        <tr>
                            <td style="width: 10%; border: none;">
                                <span t-field="payment.date"/>
                            </td>
                            <td style="width: 15%; border: none;">
                                <span t-field="payment.payment_method_line_id"/>
                            </td>
                            <td style="width: 20%; border: none;" class="text-right">
                                <span t-field="payment.amount"/>
                            </td>
                        	<td style="width: 30%; border: none;" class="text-right">
