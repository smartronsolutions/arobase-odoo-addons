<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="quote_checkout_button" inherit_id="website_sale.cart_lines" name="Quote Checkout Button">
        <xpath expr="//div[@t-foreach='website_sale_order.website_order_line']" position="after">
            <div class="mt-3">
                <a t-if="not optional_products and website_sale_order and website_sale_order.website_order_line" class=" btn btn-primary mb32 quote-checkout-button float-end" href="/quotation">
                    <span>Request Quotation </span>
                    <span class="fa fa-chevron-right" />
                </a>
            </div>
        </xpath>
    </template>

    <template id="qt_thanks_page" >
            <t name="Thanks (Quatation)" t-name="md_website_quotation_request.quatation_thanks">
                <t t-call="website.layout">
                    <div id="wrap" class="oe_structure oe_empty">
                        <section class="s_text_block pt40 pb40 o_colored_level " data-snippet="s_text_block">
                            <div class="container s_allow_columns">
                                <div class="row">
                                    <div class="col-lg-7 col-xl-6 me-lg-auto">
                                        <span class="d-block fa fa-4x fa-thumbs-up mx-auto rounded-circle bg-primary" /><br />
                                        <h1 class="text-center">Thank You!</h1>
                                        <div class="pb16 pt16 s_hr" data-snippet="s_hr" data-name="Separator">
                                            <hr class="mx-auto border-top w-50 border-dark text-center" />
                                        </div>
                                        <h5 class="text-center">
                                            <span class="fa fa-check-circle" />
                                            <span>Your Quotation Request has been sent <b>successfully</b></span>
                                        </h5>
                                        <p class="text-center" style="margin-bottom: 5px;">Your Quotation number is: <b><t t-esc="order_reference" /></b></p>
                                        <p class="text-center">We will get back to you shortly.</p>
                                    </div>
                                    <div class="col-lg-4">
                                        <ul class="list-unstyled mb-0 ps-2">
                                            <li>My Company</li>
                                            <li><i class="fa fa-map-marker fa-fw me-2" /><span class="o_force_ltr">3575 Fake Buena Vista Avenue</span></li>
                                            <li><i class="fa fa-phone fa-fw me-2" /><span class="o_force_ltr">+1 (650) 555-0111</span></li>
                                            <li><i class="fa fa-1x fa-fw fa-envelope me-2" /><span>info@yourcompany.example.com</span></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>
                    <input t-if='website.plausible_shared_key' type='hidden' class='js_plausible_push' data-event-name='Lead Generation' data-event-params='{"CTA": "Contact Us"}' />
                </t>
            </t>
    </template>
</odoo>