<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_for_quotation" model="mail.template">
            <field name="name">Quotation of Order: Send by email</field>
            <field name="model_id" ref="sale.model_sale_order" />
            <field name="subject">{{ object.company_id.name }} {{ object.state in ('draft', 'sent') and 'Quotation' or 'Order' }} (Ref {{ object.name or 'n/a' }} )</field>
            <field name="email_from">"{{ object.company_id.name }}" &lt;{{ (object.company_id.email or user.email) }}&gt;</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        <t t-set="doc_name" t-value="'quotation' if object.state in ('draft', 'sent') else 'order'" />
                        Hello,
                        <br /><br />
                        Thanks for your interest. We're preparing more information and will contact you soon.
                        <br /><br />
                        Feel free to ask any questions if needed.
                        <br />
                    </p>
                </div>
            </field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="auto_delete" eval="True" />
        </record>
    </data>
</odoo>