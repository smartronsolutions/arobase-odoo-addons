<?xml version="1.0" encoding="utf-8"?>
<odoo>    
    
    <!-- Purchase Order Tree View - Add Sale Order Count -->
    <record id="view_purchase_order_tree_inherit_sale_link" model="ir.ui.view">
        <field name="name">purchase.order.tree.sale.link</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_view_tree"/>
        <field name="arch" type="xml">
            <field name="amount_total" position="after">
                <field name="sale_order_count" string="SO Count" optional="hide"/>
            </field>
        </field>
    </record>
    
</odoo>