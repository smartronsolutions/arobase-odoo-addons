<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <template id="report_purchaseorder_document_custom" inherit_id="purchase.report_purchaseorder_document">
            <!-- Modification de l'en-tête des colonnes pour les bons de commande -->
            <xpath expr="//th[@name='th_description']" position="before">
                <th name="th_ref" class="text-start">
                    <span>Code</span>
                </th>
            </xpath>

            <!-- Modification du contenu des lignes pour les bons de commande -->
            <xpath expr="//td[@id='product']" position="before">
                <td name="td_ref" class="text-start">
                    <span t-field="line.product_id.default_code"/>
                </td>
            </xpath>
    </template>
</odoo>