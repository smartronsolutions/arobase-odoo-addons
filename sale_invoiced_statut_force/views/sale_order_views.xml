<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Vue formulaire avec boutons pour forcer/recalculer le statut -->
        <record id="view_sale_order_form_force_invoice" model="ir.ui.view">
            <field name="name">sale.order.form.force.invoice</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <!--<button name="action_force_invoiced_status" 
                            type="object" 
                            string="Force invoice statuts on 'Fully invoiced'"
                            class="btn-warning"
                            invisible="invoice_status == 'invoiced' or state not in ['sale', 'done']"
                            groups="sales_team.group_sale_manager"/>-->
                    <field name="is_invoice_status_forced" invisible="1"/>
                    <button name="action_reset_invoice_status" 
                            type="object" 
                            string="Reset invoice status"
                            class="btn-secondary"
                            invisible="not is_invoice_status_forced"
                            groups="sales_team.group_sale_manager"/>
                </xpath>
            </field>
        </record>

    
        <!-- Ajout Action forcer le statut depuis les actions de sale order -->
        <record id="action_server_force_invoice_status" model="ir.actions.server">
            <field name="name">Mark invoice status as 'Fully invoiced'</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="binding_view_types">form</field>
            <field name="state">code</field>
            <field name="groups_id" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
            <field name="code">
        action = records.action_force_invoiced_status()
            </field>
        </record>
    
    
    </data>
</odoo>