<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Vue formulaire du wizard -->
        <record id="view_sale_force_invoice_wizard_form" model="ir.ui.view">
            <field name="name">sale.force.invoice.wizard.form</field>
            <field name="model">sale.force.invoice.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <div class="alert alert-warning mb-3">
                        <div class="d-flex align-items-center">
                            <i class="fa fa-exclamation-triangle fa-2x me-3 text-warning"></i>
                            <div>
                                <h5 class="alert-heading mb-1">Warning</h5>
                                <p class="mb-0">You are forcing the invoice status of this order as <strong>"Fully invoiced"</strong>.</p>
                                <small>This action must be justified and will be recorded in the order history.</small>
                            </div>
                        </div>
                    </div>
                    
                    <group>
                        <group>
                            <field name="sale_order_id" readonly="1"/>
                        	<field name="current_status" readonly="1"/>
                        </group>
                        <group>
                            <separator string="Reason" colspan="2"/>
                            <field name="reason" 
                                   required="1" 
                                   widget="text"
                                   colspan="2"/>
                        </group>
                    </group>
                    
                    <footer>
                        <button name="action_confirm_force" 
                                string="Confirm" 
                                type="object" 
                                class="btn-warning"/>
                        <button string="Cancel" 
                                class="btn-secondary" 
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        
        <!-- Action pour ouvrir le wizard -->
        <record id="action_sale_force_invoice_wizard" model="ir.actions.act_window">
            <field name="name">Force invoice status as "Fully invoiced"</field>
            <field name="res_model">sale.force.invoice.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{}</field>
        </record>
        
    </data>
</odoo>