<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue liste des véhicules -->
    <record id="view_vehicle_vehicle_tree" model="ir.ui.view">
        <field name="name">vehicle.vehicle.tree</field>
        <field name="model">vehicle.vehicle</field>
        <field name="arch" type="xml">
            <tree string="Vehicles">
                <field name="license_plate"/>
                <field name="partner_id"/>
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="year" widget="char"/>
                <field name="current_mileage"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Vue formulaire des véhicules -->
    <record id="view_vehicle_vehicle_form" model="ir.ui.view">
        <field name="name">vehicle.vehicle.form</field>
        <field name="model">vehicle.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!--<button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>-->
                        <button name="action_view_mileage_history" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-tachometer"
                                invisible="mileage_count == 0">
                            <field name="mileage_count" widget="statinfo" string="Mileage"/>
                        </button>
                    	<button name="action_view_invoices" 
        						type="object" 
        						class="oe_stat_button" 
        						icon="fa-pencil-square-o"
        						invisible="invoice_count == 0">
    						<field name="invoice_count" widget="statinfo" string="Invoices"/>
						</button>
                    </div>
                    
                    <div class="oe_title">
                		<div class="o_row">
                        	<h1 class="d-flex">
                            	<field name="license_plate" placeholder="Licence plate..."/>
                        	</h1>
                        	<div class="ms-auto d-flex align-items-center">
            					<label for="active" class="me-2">Active :</label>
            					<field name="active" widget="boolean_button" nolabel="1"/>
        					</div>
                    	</div>
                        <h2>
                            <field name="display_name" readonly="1"/>
                        </h2>
                    	<!-- Désactiver le commentaire si vous souhaitez créer une facture depuis le formulaire de véhicule-->
                    	<!--<div class="o_row">
        					<button name="action_create_invoice_with_mileage" 
                					string="Créer une facture" 
                					type="object" 
                					class="btn btn-primary"/>
    					</div>-->
                    </div>
                    
                    <group>
                        <group string="General information">
                            <field name="partner_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="brand_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="model_id" options="{'no_create': True, 'no_create_edit': True}"
                                   domain="[('brand_id', '=', brand_id)]"/>
                            <field name="vin"/>
                        </group>
                        <group string="Features">
                            <field name="year" widget="char"/>
                            <field name="fuel_type"/>
                            <field name="transmission"/>
                            <field name="doors"/>
                            <field name="seats"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Technical">
                            <field name="engine"/>
                            <field name="current_mileage"/>
                        </group>
                        <group string="Administrative">
                            <field name="first_registration"/>
                            <field name="circulation_date"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Mileage history" name="mileage_history">
                            <field name="mileage_ids">
                                <tree editable="bottom" default_order="date desc">
                                    <field name="date"/>
                                    <field name="mileage" widget="integer"/>
                                    <field name="mileage_difference" widget="integer" readonly="1" optional="hide"/>
                                    <field name="user_id" readonly="1"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                    	<page string="Compatibility" name="compatibility">
                            <separator string="Compatibility category"/>
                            <field name="compatibility_category_ids">
                                <tree editable="bottom">
                                    <field name="complete_name" string="Name"/>
                                    <field name="brand_id"/>
                                    <field name="model_id"/>
                                    <field name="year_id"/>
                                    <field name="series_id"/>
                                    <field name="variant_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                
					<separator string="Notes"/>
                    <field name="notes" nolabel="0"/>
                
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vue kanban des véhicules -->
    <record id="view_vehicle_vehicle_kanban" model="ir.ui.view">
        <field name="name">vehicle.vehicle.kanban</field>
        <field name="model">vehicle.vehicle</field>
        <field name="arch" type="xml">
            <kanban string="Vehicles">
                <field name="license_plate"/>
                <field name="partner_id"/>
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="year"/>
                <field name="current_mileage"/>
                <field name="circulation_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="license_plate"/>
                                        </strong>
                                        <br/>
                                        <span>
                                            <field name="brand_id"/> <field name="model_id"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="partner_id"/>
                                    <br/>
                                    <span t-if="record.year.value">
                                        Year: <field name="year" widget="char"/>
                                    </span>
                                    <br/>
                                    <span t-if="record.current_mileage.value">
                                        <field name="current_mileage"/> km
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vue recherche des véhicules -->
    <record id="view_vehicle_vehicle_search" model="ir.ui.view">
        <field name="name">vehicle.vehicle.search</field>
        <field name="model">vehicle.vehicle</field>
        <field name="arch" type="xml">
            <search string="Search vehicle">
                <field name="license_plate" string="Licence plate"/>
                <field name="partner_id" string="Client"/>
                <field name="brand_id" string="Brand"/>
                <field name="model_id" string="Model"/>
                <field name="vin" string="VIN"/>
                <field name="name" string="Name"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
                <separator/>
                <filter string="Under 5 years old" name="recent" domain="[('year','&gt;=', (context_today() - relativedelta(years=5)).year)]"/>
                <filter string="More than 10 years" name="old" domain="[('year','&lt;=', (context_today() - relativedelta(years=10)).year)]"/>
                <group expand="0" string="Group by">
                    <filter string="Client" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Brand" name="group_brand" context="{'group_by': 'brand_id'}"/>
                    <filter string="Model" name="group_model" context="{'group_by': 'model_id'}"/>
                    <filter string="Year" name="group_year" context="{'group_by': 'year'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action des véhicules -->
    <record id="action_vehicle_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">vehicle.vehicle</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_vehicle_vehicle_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first vehicle
            </p>
            <p>
                Manage your customers' vehicles with all their features.
            </p>
        </field>
    </record>
</odoo>