<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue liste des modèles -->
    <record id="view_vehicle_model_tree" model="ir.ui.view">
        <field name="name">vehicle.model.tree</field>
        <field name="model">vehicle.model</field>
        <field name="arch" type="xml">
            <tree string="Vehicle models">
                <field name="brand_id"/>
                <field name="name"/>
                <field name="vehicle_count" string="Vehicle"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Vue formulaire des modèles -->
    <record id="view_vehicle_model_form" model="ir.ui.view">
        <field name="name">vehicle.model.form</field>
        <field name="model">vehicle.model</field>
        <field name="arch" type="xml">
            <form string="Vehicle model">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    
                    <group>
                        <group>
                            <field name="brand_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="display_name"/>
                            <field name="vehicle_count"/>
                        </group>
                    </group>
                    
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue recherche des modèles -->
    <record id="view_vehicle_model_search" model="ir.ui.view">
        <field name="name">vehicle.model.search</field>
        <field name="model">vehicle.model</field>
        <field name="arch" type="xml">
            <search string="Search models">
                <field name="name" string="Model"/>
                <field name="brand_id" string="Brand"/>
                <field name="display_name" string="Complete name"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
                <group expand="0" string="Group by">
                    <filter string="Brand" name="group_brand" context="{'group_by': 'brand_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action des modèles -->
    <record id="action_vehicle_model" model="ir.actions.act_window">
        <field name="name">Models</field>
        <field name="res_model">vehicle.model</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_vehicle_model_search"/>
        <field name="context">{'search_default_active': 1, 'search_default_group_brand': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first vehicle model
            </p>
            <p>
                Manage vehicle models by brand.
            </p>
        </field>
    </record>
</odoo>