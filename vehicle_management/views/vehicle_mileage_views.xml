    <!-- Vue recherche des relevés kilométriques -->
    <record id="view_vehicle_mileage_search" model="ir.ui.view">
        <field name="name">vehicle.mileage.search</field>
        <field name="model">vehicle.mileage</field>
        <field name="arch" type="xml">
            <search string="Mileage search">
                <field name="vehicle_id" string="Vehicle"/>
                <field name="partner_id" string="Client"/>
                <field name="date" string="Date"/>
                <separator/>
                <filter string="This month" name="current_month" 
                        domain="[('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                ('date', '&lt;=', (context_today() + relativedelta(months=1, day=1, days=-1)).strftime('%Y-%m-%d'))]"/>
                <filter string="This quarter" name="current_quarter" 
                        domain="[('date', '&gt;=', time.strftime('%Y-%m-01')), ('date', '&lt;=', time.strftime('%Y-%m-%d'))]"/>
                <separator/>
                <!--<filter string="Avec facture" name="with_invoice" domain="[('invoice_id', '!=', False)]"/>
                <filter string="Sans facture" name="without_invoice" domain="[('invoice_id', '=', False)]"/>-->
                <group expand="0" string="Group by">
                    <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action des relevés kilométriques -->
    <record id="action_vehicle_mileage" model="ir.actions.act_window">
        <field name="name">Mileage statement</field>
        <field name="res_model">vehicle.mileage</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_vehicle_mileage_search"/>
        <field name="context">{'search_default_current_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first mileage report
            </p>
            <p>
                Track the mileage of your vehicle's customer.
            </p>
        </field>
    </record>
</odoo>