<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue liste des relevés kilométriques -->
    <record id="view_vehicle_mileage_tree" model="ir.ui.view">
        <field name="name">vehicle.mileage.tree</field>
        <field name="model">vehicle.mileage</field>
        <field name="arch" type="xml">
            <tree string="Mileage statement" default_order="date desc">
                <field name="date"/>
                <field name="mileage" widget="integer"/>
                <field name="mileage_difference" widget="integer" optional="hide"/>
                <field name="user_id"/>
            	<!--<field name="invoice_id"/>-->

            </tree>
        </field>
    </record>

