<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue formulaire du wizard de création facture -->
    <record id="view_vehicle_invoice_wizard_form" model="ir.ui.view">
        <field name="name">vehicle.invoice.wizard.form</field>
        <field name="model">vehicle.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Create invoice">
                <group string="Vehicle information">
                    <field name="vehicle_id" readonly="1"/>
                    <field name="partner_id" readonly="1"/>
                    <field name="current_mileage" readonly="1"/>
                </group>
                
                <group string="New mileage (required)">
                    <group>
                        <field name="new_mileage" class="oe_inline"/>
                        <field name="mileage_date"/>
                    </group>
                </group>
            	
            	<separator string="Notes"/>
                <field name="notes" nolabel="1" placeholder="Notes concerning this mileage..."/>
                
                <group string="Invoice information">
                    <field name="invoice_date"/>
                </group>
                
                <footer>
                    <button name="action_create_invoice" 
                            string="Create the invoice" 
                            type="object" 
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action du wizard -->
    <record id="action_vehicle_invoice_wizard" model="ir.actions.act_window">
        <field name="name">Create invoice with mileage</field>
        <field name="res_model">vehicle.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>