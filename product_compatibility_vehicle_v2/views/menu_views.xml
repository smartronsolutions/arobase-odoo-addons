    <menuitem id="menu_product_compatibility_search_sales" 
              name="Product compatibility" 
              parent="sale.product_menu_catalog"
              action="action_product_compatibility_view" 
              sequence="10"/>

    <!-- ======================================== -->
    <!-- ACTION DE SYNCHRONISATION  pour modèle product_compatibility_views      -->
    <!-- ======================================== -->

    <!-- Action pour synchronisation manuelle -->
    <record id="action_sync_compatibility_relations" model="ir.actions.server">
        <field name="name">Synchronize compatibility relationships</field>
        <field name="model_id" ref="model_product_compatibility_view"/>
        <field name="state">code</field>
        <field name="code">
# Synchronisation de toutes les relations
relation_count = model.sync_all_products()
action = {
    'type': 'ir.actions.client',
    'tag': 'display_notification',
    'params': {
        'title': _('Synchronization complete'),
        'message': _('%d relationship(s) created/updated') % relation_count,
        'type': 'success',
        'sticky': False,
    }
}
        </field>
    </record>

