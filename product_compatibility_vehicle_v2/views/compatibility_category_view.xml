<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================================== -->
    <!-- VUES POUR COMPATIBILITY.CATEGORY        -->
    <!-- ======================================== -->

    <!-- Vue Liste des Catégories de Compatibilité -->
    <record id="view_compatibility_category_list" model="ir.ui.view">
        <field name="name">compatibility.category.list</field>
        <field name="model">compatibility.category</field>
        <field name="arch" type="xml">
            <tree string="Compatibility category" 
                  decoration-muted="not active"
                  expand="1">
                <field name="complete_name"/>
                <field name="brand_id" optional="hide"/>
                <field name="model_id" optional="hide"/>
                <field name="year_id" optional="hide"/>
                <field name="series_id" optional="hide"/>
                <field name="variant_id" optional="hide"/>
                <field name="product_count" string="Product" optional="hide"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Vue Formulaire des Catégories de Compatibilité -->
    <record id="view_compatibility_category_form" model="ir.ui.view">
        <field name="name">compatibility.category.form</field>
        <field name="model">compatibility.category</field>
        <field name="arch" type="xml">
            <form string="Compatibility category">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_products" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-cube"
                                invisible="product_count == 0">
                            <field name="product_count" widget="statinfo" string="Product"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" 
                            invisible="active == True"/>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Category name"/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="parent_id" 
                                   placeholder="Parent category (optionnal)"
                                   domain="[('id', '!=', id)]"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>

					<separator string="Description"/>
					<field name="description" nolabel="1" placeholder="Description of the category..."/>

                    <!--<notebook>
                        <page string="Produits compatibles" name="products">
                            <field name="product_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="default_code" optional="show"/>
                                    <field name="name"/>
