    <!-- Vue de Recherche -->
    <record id="view_compatibility_category_search" model="ir.ui.view">
        <field name="name">compatibility.category.search</field>
        <field name="model">compatibility.category</field>
        <field name="arch" type="xml">
            <search string="Product compatibility search">

                <!-- 🔍 Searchable fields -->
                <field name="complete_name" string="Category"/>
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="year_id"/>
                <field name="series_id"/>
                <field name="variant_id"/>

                <separator/>

                <!-- ✅ Filters -->
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>

                <separator/>

                <!-- 📊 Group By -->
                <group expand="0" string="Group By">
                    <filter string="Brand" name="group_brand" context="{'group_by': 'brand_id'}"/>
                    <filter string="Model" name="group_model" context="{'group_by': 'model_id'}"/>
                    <filter string="Year" name="group_year" context="{'group_by': 'year_id'}"/>
                    <filter string="Series" name="group_series" context="{'group_by': 'series_id'}"/>
                    <filter string="Variant" name="group_variant" context="{'group_by': 'variant_id'}"/>
                </group>

            </search>
        </field>
    </record>


    <!-- Action pour les Catégories de Compatibilité -->
    <record id="action_compatibility_category" model="ir.actions.act_window">
        <field name="name">Compatibility category</field>
        <field name="res_model">compatibility.category</field>
        <!--<field name="view_mode">tree,kanban,form</field>-->
    	<field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_compatibility_category_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first compatibility category!
            </p>
            <p>
                Compatibility categories allow you to organize your products 
                according to their compatibility (vehicles, electronic devices, etc.).
            </p>
        </field>
    </record>

