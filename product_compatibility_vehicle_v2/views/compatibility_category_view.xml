                                    <field name="list_price" optional="show"/>
                                    <field name="standard_price" optional="hide"/>
                                    <field name="qty_available" optional="show"/>
                                    <field name="uom_id" optional="hide"/>
                                    <field name="active" optional="hide"/>
                                </tree>
                            </field>
                        </page>-->
                        
                        <!--<page string="Catégories enfants" name="children" 
                              invisible="not child_ids">
                            <field name="child_ids" nolabel="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="product_count"/>
                                    <field name="active"/>
                                </tree>
                            </field>
                        </page>-->
                    <!--</notebook>-->

                </sheet>
            </form>
        </field>
    </record>

